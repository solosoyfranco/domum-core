#!/usr/bin/env bash
set -euo pipefail

DOMUM_DIR="${DOMUM_DIR:-/opt/domum-core}"
CFG_FILE="${CFG_FILE:-$DOMUM_DIR/config/domum.conf}"

die() {
  echo "ERROR: $*" >&2
  exit 1
}

need_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    die "Run as root (use sudo)."
  fi
}

load_cfg() {
  if [[ ! -f "$CFG_FILE" ]]; then
    die "Missing config: $CFG_FILE"
  fi
  # shellcheck disable=SC1090
  source "$CFG_FILE"
}

cmd_exists() { command -v "$1" >/dev/null 2>&1; }

install_docker() {
  echo "[domum] Ensuring Docker + Compose plugin..."
  if cmd_exists docker && docker compose version >/dev/null 2>&1; then
    echo "[domum] Docker already present."
    return 0
  fi

  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y --no-install-recommends ca-certificates curl gnupg lsb-release

  install -m 0755 -d /etc/apt/keyrings
  if [[ ! -f /etc/apt/keyrings/docker.gpg ]]; then
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
  fi

  local arch
  arch="$(dpkg --print-architecture)"
  local codename
  codename="$(. /etc/os-release && echo "${VERSION_CODENAME}")"

  echo \
    "deb [arch=${arch} signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian ${codename} stable" \
    >/etc/apt/sources.list.d/docker.list

  apt-get update -y
  apt-get install -y --no-install-recommends docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

  systemctl enable --now docker
  echo "[domum] Docker installed."
}

ensure_dirs() {
  mkdir -p "$DOMUM_DIR/data" "$DOMUM_DIR/logs"
}

repo_update() {
  echo "[domum] Updating repo in $DOMUM_DIR..."
  if [[ ! -d "$DOMUM_DIR/.git" ]]; then
    die "$DOMUM_DIR is not a git repo. Reinstall using install.sh"
  fi
  git -C "$DOMUM_DIR" fetch --all --prune
  git -C "$DOMUM_DIR" reset --hard origin/main
  echo "[domum] Repo updated."
}

compose_files_for_enabled_services() {
  # Prints a list of "-f file.yml" parts
  local files=()
  files+=("$DOMUM_DIR/compose/base.yml")

  # Proxy
  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/proxy/traefik.yml")
  fi

  # Automation
  if [[ "${ENABLE_HOME_ASSISTANT:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/automation/home-assistant.yml")
  fi
  if [[ "${ENABLE_MQTT:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/automation/mqtt.yml")
  fi
  if [[ "${ENABLE_ZIGBEE2MQTT:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/automation/zigbee2mqtt.yml")
  fi
  if [[ "${ENABLE_NODERED:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/automation/nodered.yml")
  fi
  if [[ "${ENABLE_ESP_HOME:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/automation/esphome.yml")
  fi

  # Monitoring
  if [[ "${ENABLE_UPTIME_KUMA:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/monitoring/uptime-kuma.yml")
  fi
  if [[ "${ENABLE_PORTAINER:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/monitoring/portainer.yml")
  fi

  # Media
  if [[ "${ENABLE_JELLYFIN:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/jellyfin.yml")
  fi

  # Networking
  if [[ "${ENABLE_ADGUARD_HOME:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/networking/adguard-home.yml")
  fi

  # Security
  if [[ "${ENABLE_TAILSCALE:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/security/tailscale.yml")
  fi

  for f in "${files[@]}"; do
    [[ -f "$f" ]] || die "Missing compose file: $f"
    echo "-f"
    echo "$f"
  done
}

profiles_for_apply() {
  # core always
  local profiles=("core")
  if [[ "${ENABLE_NIGHT_PROFILE:-0}" == "1" ]]; then
    profiles+=("night")
  fi
  if [[ "${ENABLE_MEDIA_PROFILE:-0}" == "1" ]]; then
    profiles+=("media")
  fi
  if [[ "${ENABLE_AI_PROFILE:-0}" == "1" ]]; then
    profiles+=("ai")
  fi
  printf "%s\n" "${profiles[@]}"
}

export_env_for_compose() {
  # Domain and email for ACME
  export DOMUM_DOMAIN="${DOMUM_DOMAIN:-ladomum.com}"
  export DOMUM_EMAIL="${DOMUM_EMAIL:-admin@ladomum.com}"

  # Host IPs, optional
  export DOMUM_LAN_IP="${DOMUM_LAN_IP:-}"
  export DOMUM_TS_IP="${DOMUM_TS_IP:-}"

  # Cloudflare token
  if [[ -z "${CF_DNS_API_TOKEN:-}" ]]; then
    if [[ -f "/etc/domum-core/secrets/cloudflare_api_token" ]]; then
      CF_DNS_API_TOKEN="$(cat /etc/domum-core/secrets/cloudflare_api_token)"
      export CF_DNS_API_TOKEN
    fi
  fi
}

compose_cmd() {
  local -a args
  mapfile -t args < <(compose_files_for_enabled_services)
  cd "$DOMUM_DIR"
  docker compose "${args[@]}" "$@"
}

init_host() {
  need_root
  load_cfg
  install_docker
  ensure_dirs

  # Create local override files if missing
  if [[ ! -f "/etc/domum-core/secrets/cloudflare_api_token" ]]; then
    echo "[domum] NOTE: secrets/cloudflare_api_token not found."
    echo "        If you want real TLS certs via Cloudflare DNS-01, create:"
    echo "        /etc/domum-core/secrets/cloudflare_api_token"
  fi

  # Create a default .env for services that use it (optional)
  if [[ ! -f "$DOMUM_DIR/.env" ]]; then
    cat >"$DOMUM_DIR/.env" <<EOF
# Optional per-host env file (not required for most services)
# Example:
# SOME_PASSWORD=change-me
EOF
    chmod 0600 "$DOMUM_DIR/.env"
  fi

  echo "[domum] Init complete."
}

apply() {
  need_root
  load_cfg
  export_env_for_compose

  # sanity
  install_docker
  ensure_dirs

  # Build profile flags
  local -a profile_flags=()
  while IFS= read -r p; do
    profile_flags+=("--profile" "$p")
  done < <(profiles_for_apply)

  echo "[domum] Applying desired state..."
  compose_cmd "${profile_flags[@]}" up -d --remove-orphans

  # Optional: stop night-only profile outside the night window if desired
  if [[ "${ENABLE_NIGHT_PROFILE:-0}" == "1" && "${NIGHT_AUTOSTOP_OUTSIDE_WINDOW:-1}" == "1" ]]; then
    domum_night_autostop
  fi

  echo "[domum] Apply done."
}

domum_night_autostop() {
  # If current time is outside the window, stop containers in the night profile.
  # This is a best-effort safety net. Scheduling is primarily handled by timers.
  local up="${NIGHT_UP_TIME:-23:00}"
  local down="${NIGHT_DOWN_TIME:-07:00}"

  local now
  now="$(date +%H:%M)"

  # Determine if we're inside window, accounting for windows that cross midnight.
  # If up < down: window within same day.
  # If up > down: window crosses midnight.
  if [[ "$up" < "$down" ]]; then
    if [[ "$now" < "$up" || "$now" > "$down" ]]; then
      echo "[domum] Outside night window, stopping night profile."
      compose_cmd --profile night stop || true
    fi
  else
    # crosses midnight: inside if now >= up OR now <= down
    if [[ "$now" < "$up" && "$now" > "$down" ]]; then
      echo "[domum] Outside night window, stopping night profile."
      compose_cmd --profile night stop || true
    fi
  fi
}

status() {
  need_root
  load_cfg
  export_env_for_compose
  echo "[domum] Status:"
  compose_cmd ps
}

schedule_install() {
  need_root
  load_cfg
  local script="$DOMUM_DIR/bin/night-profile.sh"
  install -m 0755 "$script" /usr/local/bin/domum-night-profile

  local up="${NIGHT_UP_TIME:-23:00}"
  local down="${NIGHT_DOWN_TIME:-07:00}"

  # Create services + timers
  cat >/etc/systemd/system/domum-night-up.service <<EOF
[Unit]
Description=Start domum night profile
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/domum-night-profile up
EOF

  cat >/etc/systemd/system/domum-night-down.service <<EOF
[Unit]
Description=Stop domum night profile
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/domum-night-profile down
EOF

  # Timers (daily at HH:MM)
  local up_h="${up%:*}"
  local up_m="${up#*:}"
  local down_h="${down%:*}"
  local down_m="${down#*:}"

  cat >/etc/systemd/system/domum-night-up.timer <<EOF
[Unit]
Description=Timer to start domum night profile

[Timer]
OnCalendar=*-*-* ${up_h}:${up_m}:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

  cat >/etc/systemd/system/domum-night-down.timer <<EOF
[Unit]
Description=Timer to stop domum night profile

[Timer]
OnCalendar=*-*-* ${down_h}:${down_m}:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

  systemctl daemon-reload
  systemctl enable --now domum-night-up.timer domum-night-down.timer

  echo "[domum] Night profile scheduling installed."
  echo "        Start time: $up"
  echo "        Stop time:  $down"
}

schedule_remove() {
  need_root
  systemctl disable --now domum-night-up.timer domum-night-down.timer || true
  rm -f /etc/systemd/system/domum-night-up.timer /etc/systemd/system/domum-night-down.timer
  rm -f /etc/systemd/system/domum-night-up.service /etc/systemd/system/domum-night-down.service
  rm -f /usr/local/bin/domum-night-profile
  systemctl daemon-reload
  echo "[domum] Night profile scheduling removed."
}

usage() {
  cat <<EOF
domum (domum-core)

Usage:
  domum init
  domum apply
  domum update
  domum status
  domum schedule install
  domum schedule remove

Config:
  $CFG_FILE

Env:
  DOMUM_DIR=$DOMUM_DIR
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
  init)
    shift
    init_host "$@"
    ;;
  apply)
    shift
    apply "$@"
    ;;
  update)
    shift
    repo_update "$@"
    ;;
  status)
    shift
    status "$@"
    ;;
  schedule)
    shift
    case "${1:-}" in
    install)
      shift
      schedule_install "$@"
      ;;
    remove)
      shift
      schedule_remove "$@"
      ;;
    *)
      usage
      exit 1
      ;;
    esac
    ;;
  *)
    usage
    exit 1
    ;;
  esac
}

main "$@"
